    },
    {
      "name": "World Bank / IEA",
      "type": "International benchmark databases",
      "years": "2022–2023",
      "indicators": ["energy_cost_per_kwh", "subsidy_access_rate"]
    },
    {
      "name": "Local Government Engineering Department (LGED)",
